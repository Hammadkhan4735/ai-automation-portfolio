    {
      "parameters": {
        "jsCode": "// 1. Get the draft email content\nlet emailContent = $('If Action Approve').first().json.draft_email ;\n\n// 2. Escape double quotes and backslashes to prevent JSON breakage\n// 3. Replace actual line breaks with the characters \\n\nconst sanitizedEmail = emailContent\n  .replace(/\\\\/g, '\\\\\\\\')  // Escape backslashes\n  .replace(/\"/g, '\\\\\"')    // Escape double quotes\n  .replace(/\\n/g, '\\\\n')   // Convert real newlines to \\n characters\n  .replace(/\\r/g, '\\\\n');  // Handle carriage returns\nconst hhmm = new Date().toLocaleTimeString('en-US', { \n  hour: '2-digit', \n  minute: '2-digit' \n});\n\nreturn {\n  request_id:$('If Action Approve').first().json.request_id,\n  is_email_sent: $('If Action Approve').first().json.is_email_sent,\n  subject: $('If Action Approve').first().json.subject,\n  email_summary: $('If Action Approve').first().json.email_summary,\n  sender: $('If Action Approve').first().json.sender,\n  draft_email: sanitizedEmail,\n  slack_channel_id: $('If Action Approve').first().json.slack_channel_id,\n    slack_msg_timestamp: $('If Action Approve').first().json.slack_msg_timestamp,\n  mcurrent_time: hhmm\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
