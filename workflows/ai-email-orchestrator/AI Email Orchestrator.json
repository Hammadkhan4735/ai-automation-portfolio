    {
      "parameters": {
        "jsCode": "const rawPayload = $input.first().json.body;\n\nconst payload = rawPayload.payload;\n\nconst parsedPayload = JSON.parse(payload);\n\n\n//3. Access the value safely\nconst value = parsedPayload.actions?.[0]?.value || \"\";\n\n// 4. Split the value (e.g., \"approve_19da728b80a2cbc1\")\nconst parts = value.split(\"_\");\nconst action = parts[0];\nconst requestId = parts[1];\n\n// 5. Return in the standard n8n format\nreturn [\n  {\n    json: {\n      action: action,\n      requestId: requestId,\n      user: parsedPayload.user.name // Bonus: tracking who clicked it\n    }\n  }\n];;"
      },
