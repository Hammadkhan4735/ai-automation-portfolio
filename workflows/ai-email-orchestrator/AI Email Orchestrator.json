    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// 1. Extract Subject from headers array\n\n\nconst subject = $input.first().json.Subject\n\n// 2. Extract Sender from headers array\n\nconst sender = $input.first().json.From\n\n// 3. Extract Request ID from snippet (as before)\nconst snippet = item.snippet || \"\";\nconst requestIdMatch = snippet.match(/\\d{10,}/);\nconst requestId = $input.first().json.id ;\n\n// 4. Return structured object for your AI Agent\nreturn {\n    json: {\n        sender: sender,\n        subject: subject,\n        request_id: requestId,\n        summary: snippet,\n        received_at: new Date(parseInt(item.internalDate)).toISOString()\n    }\n};"
      },
